		12740 /*  -9 dBm */
		12960 /* -8 dBm */
		13150 /* -7 dBm */
		13460 /* -6 dBm */
		13770 /* -5 dBm */
		14070 /* -4 dBm */
		14460 /* -3 dBm */
		15030 /* -2 dBm */
		15440 /* -1 dBm */
		16030 /*  0 dBm */
		16980 /*  1 dBm */
		17590 /*  2 dBm */
		18270 /*  3 dBm */
		19060 /*  4 dBm */
		19900 /*  5 dBm */
		20740 /*  6 dBm */
		21610 /*  7 dBm */
		22400 /*  8 dBm */
		23370 /*  9 dBm */
		24860 /* 10 dBm */
		26410 /* 11 dBm */
		26430 /* 12 dBm */
		27890 /* 13 dBm */
		>;
	};

	/*
	 * Two MAX6675 K-type thermocouple-to-digital converters sharing this bus.
	 * Read-only devices: SCK + SO(MISO) + CS only (no MOSI); SO tri-states when
	 * deselected, so they coexist with the LR1121. Max SCK ~4.3 MHz.
	 */
	tc0: max6675@1 {
		compatible = "maxim,max6675";
		reg = <1>;                          /* CS index 1 -> D19 */
		spi-max-frequency = <DT_FREQ_M(4)>;
	};

	tc1: max6675@2 {
		compatible = "maxim,max6675";
		reg = <2>;                          /* CS index 2 -> D20 */
		spi-max-frequency = <DT_FREQ_M(4)>;
	};
};
