		17850 /*  4 dBm */
		18720 /*  5 dBm */
		19640 /*  6 dBm */
		20560 /*  7 dBm */
		21400 /*  8 dBm */
		22620 /*  9 dBm */
		23720 /* 10 dBm */
		25050 /* 11 dBm */
		26350 /* 12 dBm */
		27870 /* 13 dBm */
		28590 /* 14 dBm */
		37820 /* 15 dBm */
		>;

		tx-dbm-to-ua-reg-mode-ldo-lf-lp-vreg = <
		14950 /* -17 dBm */
		15280 /* -16 dBm */
		15530 /* -15 dBm */
		15770 /* -14 dBm */
		16020 /* -13 dBm */
		16290 /* -12 dBm */
