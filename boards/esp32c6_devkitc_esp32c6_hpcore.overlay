 * Copyright (c) 2026 Guilherme Luiz Moritz
 *
 * SPDX-License-Identifier: Apache-2.0
 *
 * Board overlay: ESP32-C6-DevKitC (interim host) + Waveshare Core1121-XF (LR1121).
 *
 * GPIO assignments follow the DUAL-SOCKET CARRIER pin map: the carrier accepts
 * EITHER an ESP32-C6 mini OR a WeAct BlackPill F411CE in overlapped, nested
 * 2.54 mm socket rows, so every net must land on both. The C6 row sits 3.81 mm
 * outboard of its BlackPill partner row and is offset 5 pitches in Y, which makes
 * each shared net a single straight stub between two adjacent pads.
 *
 * The pin choice is therefore a ROUTING result, not a preference. See README.md
 * ("Carrier pin map") for the derivation. Constraints honoured here:
 *   - GPIO12/13 are native USB (USB-Serial-JTAG)   -> never used
 *   - GPIO8 is strapping AND drives the module's onboard addressable RGB LED
 *     -> left unrouted on the carrier, so the LED stays usable
 *   - GPIO9 is strapping (boot mode)               -> dead pair, unused
 *   - GPIO15 selects the JTAG source and is sampled at reset -> carries an
 *     active-low OUTPUT only (OPTO_OUT2), never an input
 *   - GPIO4-7 are the pin-JTAG group, usable as GPIO only because GPIO15 stays
 *     high at reset (we debug over USB-JTAG)
 *   - GPIO16 is the ROM UART TX -> output-only on the carrier
 *   - the C6 GPIO matrix lets SPI2 land anywhere, so the STM32's fixed
 *     alternate-function pins are the anchor and the C6 bends to match
 *
 * Derived from usp_zephyr boards/shields/semtech_lr11xxmb1xxs. The large
 * tx-power / rssi / current tables further down are the LR1121-MB1 reference
 * values kept as a STARTING POINT; they are BOM-specific and must be
 * recalibrated for the Core1121-XF for correct RF performance.
 */

#include <zephyr/dt-bindings/usp/lr11xx.h>
#include <zephyr/dt-bindings/pinctrl/esp32c6-pinctrl.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/* LoRaWAN credentials (DevEUI / JoinEUI / AppKey / region) live here. */
#include "user_keys.overlay"

/ {
	chosen {
		zephyr,lorawan-transceiver = &lora_lr1121;
	};
	aliases {
		lora-transceiver = &lora_lr1121;
		tc0 = &tc0;
		tc1 = &tc1;
		keepalive-out = &keepalive_out;
		hw-wdt-out = &hw_wdt_out;
		opto-out2 = &opto_out2;
		opto-in1 = &opto_in1;
		opto-in2 = &opto_in2;
	};

	/*
	 * Failsafe / watchdog pulse outputs.
	 *
	 * These MUST be toggled from software (NOT hardware PWM/LEDC): the whole
	 * point is that the pulses STOP when the firmware hangs. LEDC would keep
	 * running autonomously through a CPU hang and defeat the failsafe.
	 *   - keepalive_out retriggers an external 555 monostable that gates the
	 *     power circuit; stop toggling -> 555 times out -> power shuts down.
	 *   - hw_wdt_out kicks an external hardware watchdog.
	 * Gate both on an application-liveness flag, not a bare kernel timer (the
	 * kernel keeps ticking even if the app thread is deadlocked). Both pins are
	 * Hi-Z at reset until firmware drives them, so size the external timeouts to
	 * survive boot. (gpio-leds is reused only as a generic GPIO-output binding.)
	 */
	failsafe_outputs {
		compatible = "gpio-leds";
		keepalive_out: keepalive {
			gpios = <&gpio0 21 GPIO_ACTIVE_HIGH>;   /* D21, carrier b13-right (BlackPill PA1) */
			label = "555 monostable keep-alive";
		};
		hw_wdt_out: hw-wdt {
			gpios = <&gpio0 20 GPIO_ACTIVE_HIGH>;   /* D20, carrier b14-right (BlackPill PA0) */
			label = "external hardware watchdog kick";
		};
	};

	/*
	 * Isolated 12 V field I/O. Screw terminals are open-drain (optocoupler
	 * transistor) outputs and dry-contact inputs. OUT1 is hw_wdt_out above.
	 *
	 * OUT2 sits on D15, which selects the ESP32-C6 JTAG source and is sampled at
	 * reset. It is driven ACTIVE LOW into the opto (3V3 - R - LED - pin) with an
	 * external 10k pull-up, so Hi-Z at reset = pin high = strap satisfied AND
	 * output inactive. Never make D15 an input: a field contact pulling it low at
	 * reset switches JTAG onto GPIO4-7, which would seize TC1_CS/NSS/SCK/MISO.
	 */
	opto_outputs {
		compatible = "gpio-leds";
		opto_out2: out2 {
			gpios = <&gpio0 15 GPIO_ACTIVE_LOW>;    /* D15, carrier b10-right (BlackPill PA4) */
			label = "isolated 12V output 2 (RFU)";
		};
	};

	/*
	 * Both inputs are ACTIVE LOW with external pull-ups: a failed or unpowered
	 * optocoupler reads as asserted, so a welded contactor fails toward the alarm
	 * state rather than being missed.
	 *
	 * IN2 is on GPIO23, a clean GPIO. It moved off GPIO17 when the console went
	 * back to the ROM UART pair (GPIO16/17); its BlackPill end stays PA5, so the
	 * net is now a diagonal (b9-right -> b11-right) instead of a stub.
	 */
	opto_inputs {
		compatible = "gpio-keys";
		opto_in1: in1 {
			gpios = <&gpio0 3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;    /* D3,  b7-right (PA7) */
			label = "contactor dry contact";
			zephyr,code = <INPUT_KEY_0>;
		};
		opto_in2: in2 {
			gpios = <&gpio0 23 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;   /* D23, b11-right pad -> PA5 */
			label = "isolated 12V input 2 (RFU)";
			zephyr,code = <INPUT_KEY_1>;
		};
	};
};

/*
 * Shared SPI bus: SCLK=GPIO6, MISO=GPIO7, MOSI=GPIO0.
 *
 * These face BlackPill PB3/PB4/PB5 (= SPI1 alternate mapping) at carrier rows
 * b10/b11/b12, so all three bus signals are consecutive straight stubs. Every
 * chip select is a GPIO (cs-gpios), so CSEL is deliberately absent from pinctrl.
 */
&pinctrl {
	spim2_lora: spim2_lora {
		group1 {
			pinmux = <SPIM2_MISO_GPIO7>,
				 <SPIM2_SCLK_GPIO6>;
		};
		group2 {
			pinmux = <SPIM2_MOSI_GPIO0>;
			output-low;
		};
	};
};

/*
 * uart0 is deliberately NOT remapped: it keeps the board default TX=GPIO16 /
 * RX=GPIO17, which is also where the ROM serial-download console lives. The
 * bootloader log and the Zephyr console therefore come out of the same two
 * carrier pads (module pads 27/26) and one FTDI hookup covers both.
 *
 * The BlackPill end of that net is USART2 (PA2/PA3, rows b12/b11), which cannot
 * move - so the UART is two diagonals in the channel rather than two stubs. Both
 * ends are through-hole, so they can drop to the bottom layer at the pad with no
 * vias.
 */

/* i2c0 shares GPIO6/GPIO7 with spi2; disable it so the LoRa SPI bus owns them. */
&i2c0 {
	status = "disabled";
};

/* Not used by the LoRaWAN node; disabled to cut footprint and pin conflicts. */
&wifi {
	status = "disabled";
};
&esp32_bt_hci {
	status = "disabled";
};
&ieee802154 {
	status = "disabled";
};

&spi2 {
	status = "okay";
	pinctrl-0 = <&spim2_lora>;
	pinctrl-names = "default";

	/*
	 * One CS per device on the shared bus, indexed by each child's `reg`.
	 * Neither thermocouple sits on a strapping pin. D8 is deliberately NOT used
	 * here: it is left unrouted on the carrier so the module's onboard
	 * addressable RGB LED stays usable (it needs exclusive ~800 kHz timing).
	 */
	cs-gpios = <&gpio0 5 GPIO_ACTIVE_LOW>,    /* reg 0: LR1121 NSS  (D5, b9-left)  */
		   <&gpio0 4 GPIO_ACTIVE_LOW>,    /* reg 1: MAX6675 #1  (D4, b8-left)  */
		   <&gpio0 2 GPIO_ACTIVE_LOW>;    /* reg 2: MAX6675 #2  (D2, b6-right) */

	lora_lr1121: lora@0 {
		compatible = "semtech,lr1121";
		reg = <0>;
		spi-max-frequency = <DT_FREQ_M(16)>;

		/* ---- Control pins, carrier rows b13/b15/b16 ----
		 * BUSY and DIO9 are driven by the LR1121, so both are kept OFF the
		 * strapping pins (D8/D9/D15). NRESET is a host output and idles high.
		 */
		reset-gpios = <&gpio0 1 GPIO_ACTIVE_LOW>;                        /* D1,  b13 (PB6) */
		busy-gpios  = <&gpio0 10 GPIO_ACTIVE_HIGH>;                      /* D10, b15 (PB8) */
		event-gpios = <&gpio0 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;   /* D11, b16 (PB9) = DIO9 */
		/* LR1121 DIO7 / DIO8 are broken out on the Core1121 header but unused. */

		/* TODO: confirm against Core1121 R3/R4 population (HP only vs LP+HP). */
		lf-tx-path = <LR11XX_TX_PATH_LF_LP_HP>;

		lf-clk = <LR11XX_LFCLK_XTAL>;      /* 32.768 kHz XTAL (Y2) on DIO10/DIO11 */
		reg-mode = <LR11XX_REG_MODE_DCDC>; /* DC-DC (L6 on DCC_SW) */

		/*
		 * Core1121-XF RF switch: one PE4259 selecting the LF (sub-GHz) vs HF
		 * (2.4 GHz / L-band) antenna path, driven by LR1121 DIO5 and DIO6.
		 * Sub-GHz -> DIO6 high; HF / GNSS / WiFi-scan -> DIO5 high.
		 */
		rf-sw-enable     = <(LR11XX_DIO5 | LR11XX_DIO6)>;
		rf-sw-rx-mode    = <LR11XX_DIO6>;
		rf-sw-tx-mode    = <LR11XX_DIO6>;
		rf-sw-tx-hp-mode = <LR11XX_DIO6>;
		rf-sw-tx-hf-mode = <LR11XX_DIO5>;
		rf-sw-wifi-mode  = <LR11XX_DIO5>;
		rf-sw-gnss-mode  = <LR11XX_DIO5>;

		/* Core1121 uses a 32 MHz TCXO on XTA powered by VTCXO (Y1). */
		tcxo-voltage = <LR11XX_TCXO_SUPPLY_1_8V>; /* TODO: confirm TCXO supply voltage */
		tcxo-wakeup-time = <5>;                   /* ms; TODO: confirm from TCXO datasheet */

		tx-power-cfg-lf-lp =
		/* power, pa_duty_cycle, pa_hp_sel */
		<(-15) 0x00 0x00>, /* Expected output power = -17dBm */
		<(-14) 0x00 0x00>, /* Expected output power = -16dBm */
		<(-13) 0x00 0x00>, /* Expected output power = -15dBm */
		<(-12) 0x00 0x00>, /* Expected output power = -14dBm */
		<(-11) 0x00 0x00>, /* Expected output power = -13dBm */
		<(-9) 0x00 0x00>, /* Expected output power = -12dBm */
		<(-8) 0x00 0x00>, /* Expected output power = -11dBm */
		<(-7) 0x00 0x00>, /* Expected output power = -10dBm */
		<(-6) 0x00 0x00>, /* Expected output power = -9dBm */
		<(-5) 0x00 0x00>, /* Expected output power = -8dBm */
		<(-4) 0x00 0x00>, /* Expected output power = -7dBm */
		<(-3) 0x00 0x00>, /* Expected output power = -6dBm */
		<(-2) 0x00 0x00>, /* Expected output power = -5dBm */
		<(-1) 0x00 0x00>, /* Expected output power = -4dBm */
		<( 0) 0x00 0x00>, /* Expected output power = -3dBm */
		<( 1) 0x00 0x00>, /* Expected output power = -2dBm */
		<( 2) 0x00 0x00>, /* Expected output power = -1dBm */
		<( 3) 0x00 0x00>, /* Expected output power = 0dBm */
		<( 3) 0x01 0x00>, /* Expected output power = 1dBm */
		<( 4) 0x01 0x00>, /* Expected output power = 2dBm */
		<( 7) 0x00 0x00>, /* Expected output power = 3dBm */
		<( 8) 0x00 0x00>, /* Expected output power = 4dBm */
		<( 9) 0x00 0x00>, /* Expected output power = 5dBm */
		<( 10) 0x00 0x00>, /* Expected output power = 6dBm */
		<( 12) 0x00 0x00>, /* Expected output power = 7dBm */
		<( 13) 0x00 0x00>, /* Expected output power = 8dBm */
		<( 14) 0x00 0x00>, /* Expected output power = 9dBm */
		<( 13) 0x01 0x00>, /* Expected output power = 10dBm */
		<( 13) 0x02 0x00>, /* Expected output power = 11dBm */
		<( 14) 0x02 0x00>, /* Expected output power = 12dBm */
		<( 14) 0x03 0x00>, /* Expected output power = 13dBm */
		<( 14) 0x04 0x00>, /* Expected output power = 14dBm */
		<( 14) 0x07 0x00>; /* Expected output power = 15dBm */

		tx-power-cfg-lf-hp =
		/* power, pa_duty_cycle, pa_hp_sel */
		<(  9) 0x00 0x00>, /* Expected output power = -9dBm */
		<( 10) 0x00 0x00>, /* Expected output power = -8dBm */
		<( 11) 0x00 0x00>, /* Expected output power = -7dBm */
		<( 12) 0x00 0x00>, /* Expected output power = -6dBm */
		<( 13) 0x00 0x00>, /* Expected output power = -5dBm */
		<( 13) 0x01 0x00>, /* Expected output power = -4dBm */
		<( 13) 0x02 0x00>, /* Expected output power = -3dBm */
		<( 17) 0x02 0x00>, /* Expected output power = -2dBm */
		<( 14) 0x04 0x00>, /* Expected output power = -1dBm */
		<( 12) 0x00 0x01>, /* Expected output power = 0dBm */
		<( 13) 0x00 0x01>, /* Expected output power = 1dBm */
		<( 13) 0x01 0x01>, /* Expected output power = 2dBm */
		<( 13) 0x02 0x01>, /* Expected output power = 3dBm */
		<( 15) 0x00 0x02>, /* Expected output power = 4dBm */
		<( 15) 0x04 0x01>, /* Expected output power = 5dBm */
		<( 14) 0x02 0x02>, /* Expected output power = 6dBm */
		<( 14) 0x01 0x03>, /* Expected output power = 7dBm */
		<( 17) 0x04 0x02>, /* Expected output power = 8dBm */
		<( 22) 0x00 0x01>, /* Expected output power = 9dBm */
		<( 22) 0x01 0x01>, /* Expected output power = 10dBm */
		<( 22) 0x02 0x01>, /* Expected output power = 11dBm */
		<( 22) 0x03 0x01>, /* Expected output power = 12dBm */
		<( 22) 0x00 0x03>, /* Expected output power = 13dBm */
		<( 22) 0x01 0x03>, /* Expected output power = 14dBm */
		<( 22) 0x04 0x02>, /* Expected output power = 15dBm */
		<( 22) 0x01 0x04>, /* Expected output power = 16dBm */
		<( 22) 0x02 0x04>, /* Expected output power = 17dBm */
		<( 22) 0x01 0x06>, /* Expected output power = 18dBm */
		<( 22) 0x03 0x05>, /* Expected output power = 19dBm */
		<( 22) 0x03 0x07>, /* Expected output power = 20dBm */
		<( 22) 0x04 0x06>, /* Expected output power = 21dBm */
		<( 22) 0x04 0x07>; /* Expected output power = 22dBm */

		tx-power-cfg-hf =
		/* power, pa_duty_cycle, pa_hp_sel */
		<(-18) 0x04 0x00>, //Expected output power = -18dBm
		<(-18) 0x04 0x00>, /* Expected output power = -17dBm */
		<(-17) 0x04 0x00>, /* Expected output power = -16dBm */
		<(-16) 0x04 0x00>, /* Expected output power = -15dBm */
		<(-15) 0x04 0x00>, /* Expected output power = -14dBm */
		<(-14) 0x04 0x00>, /* Expected output power = -13dBm */
		<(-14) 0x04 0x00>, /* Expected output power = -12dBm */
		<(-12) 0x04 0x00>, /* Expected output power = -11dBm */
		<(-10) 0x04 0x00>, /* Expected output power = -10dBm */
		<( -9) 0x04 0x00>, /* Expected output power = -9dBm */
		<( -8) 0x04 0x00>, /* Expected output power = -8dBm */
		<( -7) 0x04 0x00>, /* Expected output power = -7dBm */
		<( -6) 0x04 0x00>, /* Expected output power = -6dBm */
		<( -5) 0x04 0x00>, /* Expected output power = -5dBm */
		<( -4) 0x04 0x00>, /* Expected output power = -4dBm */
		<( -3) 0x04 0x00>, /* Expected output power = -3dBm */
		<( -2) 0x03 0x00>, /* Expected output power = -2dBm */
		<( -1) 0x04 0x00>, /* Expected output power = -1dBm */
		<(  0) 0x04 0x00>, /* Expected output power = 0dBm */
		<(  1) 0x00 0x00>, /* Expected output power = 1dBm */
		<(  2) 0x00 0x00>, /* Expected output power = 2dBm */
		<(  4) 0x04 0x00>, /* Expected output power = 3dBm */
		<(  5) 0x04 0x00>, /* Expected output power = 4dBm */
		<(  6) 0x04 0x00>, /* Expected output power = 5dBm */
		<(  7) 0x04 0x00>, /* Expected output power = 6dBm */
		<(  8) 0x04 0x00>, /* Expected output power = 7dBm */
		<(  9) 0x04 0x00>, /* Expected output power = 8dBm */
		<( 10) 0x04 0x00>, /* Expected output power = 9dBm */
		<( 11) 0x04 0x00>, /* Expected output power = 10dBm */
		<( 12) 0x03 0x00>, /* Expected output power = 11dBm */
		<( 13) 0x04 0x00>, /* Expected output power = 12dBm */
		<( 13) 0x00 0x00>; /* Expected output power = 13dBm */


		/* Tune is G4 G5 G6 G7 G8 G9 G10 G11 G12 G13
		 * G13hp1 G13hp2 G13hp3 G13hp4 G13hp5 G13hp6 G13hp7
		 */
		rssi-calibration-lf-offset = <0>;
		rssi-calibration-lf-tune = <12 12 14 0 1 3 4 4 3 6 6 6 6 6 6 6 6>;

		rssi-calibration-mf-offset = <0>;
		rssi-calibration-mf-tune = <2 2 2 3 3 4 5 4 4 6 5 5 6 6 6 7 6>;

		rssi-calibration-hf-offset = <2030>;
		rssi-calibration-hf-tune = <6 7 6 4 3 4 14 12 14 12 12 12 12 8 8 9 9>;

		// Current consumptions
		tx-dbm-to-ua-reg-mode-dcdc-lf-lp-vreg = <
		10820 /* -17 dBm */
		10980 /* -16 dBm */
		11060 /* -15 dBm */
		11160 /* -14 dBm */
		11300 /* -13 dBm */
		11430 /* -12 dBm */
		11550 /* -11 dBm */
