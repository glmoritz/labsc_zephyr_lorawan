		40220 /* 10 dBm */
		42800 /* 11 dBm */
		45030 /* 12 dBm */
		47900 /* 13 dBm */
		51220 /* 14 dBm */
		66060 /* 15 dBm */
		>;

		tx-dbm-to-ua-reg-mode-dcdc-lf-hp-vbat = <
		27750  /*  -9 dBm */
		29100  /*  -8 dBm */
		30320  /*  -7 dBm */
		31650  /*  -6 dBm */
		34250  /*  -5 dBm */
		35550  /*  -4 dBm */
