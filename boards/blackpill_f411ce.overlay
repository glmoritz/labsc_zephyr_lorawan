 * Copyright (c) 2026 Guilherme Luiz Moritz
 *
 * SPDX-License-Identifier: Apache-2.0
 *
 * Board overlay: WeAct STM32F411CE "Black Pill" + Waveshare Core1121-XF (LR1121)
 * + two MAX6675 thermocouples on the shared SPI1 bus.
 *
 * Pin map — DUAL-SOCKET CARRIER. The carrier accepts EITHER this BlackPill OR an
 * ESP32-C6 mini in overlapped, nested 2.54 mm socket rows, so every net lands on
 * both. The STM32 is the ANCHOR of the assignment: its SPI/USART pins are fixed
 * alternate functions, whereas the C6's GPIO matrix can follow anywhere.
 * Carrier row index b = y / 2.54 counted from the BlackPill's USB-C end.
 *
 *   LEFT row                          RIGHT row
 *   b0  PB12  LED1 (BlackPill only)   b6   PB0   MAX6675 #2 CS
 *   b1  PB13  LED2 (BlackPill only)   b7   PA7   opto IN1 (contactor)
 *   b2  PB14  LED3 (BlackPill only)   b9   PA5   opto IN2 (RFU)
 *   b3  PB15  LED4 (BlackPill only)   b10  PA4   opto OUT2 (RFU)
 *   b4  PA8   MAX6675 #1 CS           b11  PA3   USART2 RX
 *   b9  PA15  LR1121 NSS              b12  PA2   USART2 TX (console)
 *   b10 PB3   SPI1 SCK                b13  PA1   555 keep-alive
 *   b11 PB4   SPI1 MISO               b14  PA0   hardware watchdog kick
 *   b12 PB5   SPI1 MOSI
 *   b13 PB6   LR1121 NRESET           shared spare: PA6
 *   b14 PB7   reserved - see below
 *   b15 PB8   LR1121 BUSY
 *   b16 PB9   LR1121 DIO9
 *
 * PB7 (b14-left) is deliberately UNROUTED: its ESP32-C6 partner is GPIO8, which
 * drives that module's onboard addressable RGB LED. Leaving the pair NC is what
 * keeps the C6's indicator usable.
 *
 * Unusable on this board: PA11/PA12 (USB D-/D+ - BANNED from carrier nets, see
 * the cs-gpios comment), PB2 (BOOT1, outside the C6 span), PC13 (onboard LED,
 * weak RTC pin), PC14/PC15 (32.768 kHz LSE crystal, populated), VBat (sits
 * 3.81 mm from the C6 5V pad - never bridge).
 *
 * SPI1 uses its PB3/PB4/PB5 alternate mapping (not PA5/PA6/PA7) so all three bus
 * signals are consecutive on ONE socket row — that single change is what makes
 * the carrier fanout crossing-free. PA15/PB3/PB4 are JTAG pins with reset
 * pull-ups: harmless with SWD-only debug, and PA15's pull-up usefully holds
 * LR1121 NSS deasserted before firmware runs.
 *
 * Console moves from USART1 (PA9/PA10) to USART2 (PA2/PA3): PA9/PA10 sit at
 * carrier rows b5/b6 of the LEFT row, where the C6's neighbours are GND and 3V3
 * — unusable. USART2 is the only shared UART, so it is BOTH the debug console
 * and the Radioenge AT port. Those cannot coexist: build with the `at_modem`
 * snippet when a Radioenge is fitted (see snippets/at_modem/).
 *
 * The tx-power / rssi / current tables below are LR1121-MB1 reference values and
 * must be recalibrated for the Core1121-XF BOM (same as the esp32c6 overlay).
 */

#include <zephyr/dt-bindings/usp/lr11xx.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/* LoRaWAN credentials (DevEUI / JoinEUI / AppKey / region). */
#include "user_keys.overlay"

/ {
	chosen {
		zephyr,lorawan-transceiver = &lora_lr1121;
		/* Console follows the carrier's shared UART (see header). */
		zephyr,console = &usart2;
		zephyr,shell-uart = &usart2;
	};
	aliases {
		lora-transceiver = &lora_lr1121;
		tc0 = &tc0;
		tc1 = &tc1;
		keepalive-out = &keepalive_out;
		hw-wdt-out = &hw_wdt_out;
		opto-out2 = &opto_out2;
		opto-in1 = &opto_in1;
		opto-in2 = &opto_in2;
		atuart = &usart2;
		led0 = &led1;
		led1 = &led2;
		led2 = &led3;
		led3 = &led4;
	};

	/*
	 * Status LEDs. BlackPill-ONLY - the deliberate exception to the carrier's
	 * parity rule. PB12-PB15 sit at rows b0-b3, which have no ESP32-C6 neighbour
	 * at all, so four LEDs there cost nothing the C6 could have used. On the C6
	 * the equivalent indication comes from its onboard RGB LED (GPIO8), which is
	 * why row b14-left is left unrouted. Neither target loses a function; only
	 * the form of the indication differs.
	 */
	status_leds {
		compatible = "gpio-leds";
		led1: led_1 { gpios = <&gpiob 12 GPIO_ACTIVE_HIGH>; label = "LED1"; };
		led2: led_2 { gpios = <&gpiob 13 GPIO_ACTIVE_HIGH>; label = "LED2"; };
		led3: led_3 { gpios = <&gpiob 14 GPIO_ACTIVE_HIGH>; label = "LED3"; };
		led4: led_4 { gpios = <&gpiob 15 GPIO_ACTIVE_HIGH>; label = "LED4"; };
	};

	/* Isolated 12 V field I/O - see the esp32c6 overlay for the full rationale. */
	opto_outputs {
		compatible = "gpio-leds";
		opto_out2: out2 {
			gpios = <&gpioa 4 GPIO_ACTIVE_LOW>;     /* OUT2_3V3 - PA4, b10-right (D15) */
			label = "isolated 12V output 2 (RFU)";
		};
	};

	/* Both inputs active low with external pull-ups: a failed or unpowered
	 * optocoupler reads as asserted, so a welded contactor fails to alarm. */
	opto_inputs {
		compatible = "gpio-keys";
		opto_in1: in1 {
			gpios = <&gpioa 7 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;   /* IN1_3V3 - PA7, b7-right (D3) */
			label = "contactor dry contact";
			zephyr,code = <INPUT_KEY_0>;
		};
		opto_in2: in2 {
			gpios = <&gpioa 5 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;   /* IN2_3V3 - PA5, b9-right (D23) */
			label = "isolated 12V input 2 (RFU)";
			zephyr,code = <INPUT_KEY_1>;
		};
	};

	/* Software-toggled failsafe outputs (NOT hardware PWM) — pulses must stop
	 * when firmware hangs. See the esp32c6 overlay for the full rationale. */
	failsafe_outputs {
		compatible = "gpio-leds";
		keepalive_out: keepalive {
			gpios = <&gpioa 1 GPIO_ACTIVE_HIGH>;    /* LM555_ON_PULSE - PA1, b13-right (D21) */
			label = "555 monostable keep-alive";
		};
		hw_wdt_out: hw-wdt {
			gpios = <&gpioa 0 GPIO_ACTIVE_HIGH>;    /* OUT1_3V3 - PA0, b14-right (D20) */
			label = "external hardware watchdog kick";
		};
	};
};

/*
 * Shared UART. PA9/PA10 (USART1, the board default) are unusable on the carrier:
 * at rows b5/b6 their ESP32-C6 neighbours are GND and 3V3. USART2 on PA2/PA3 is
 * the only UART both sockets can reach.
 */
&usart1 {
	status = "disabled";
};

&usart2 {
	pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&spi1 {
	status = "okay";
	/* Override the board default SPI1 pinctrl (PA5/PA6/PA7 + PA4 NSS) with the
	 * PB3/PB4/PB5 alternate mapping, so the whole bus is one contiguous run of
	 * socket rows b10-b12. Every chip select is driven as a GPIO. */
	pinctrl-0 = <&spi1_sck_pb3 &spi1_miso_pb4 &spi1_mosi_pb5>;
	pinctrl-names = "default";

	/*
	 * One CS per device on the shared bus, indexed by each child's `reg`.
	 *
	 * TC1_CS is on PA8 (b4-left), NOT on PA12 at b8-left where its ESP32-C6
	 * partner D4 sits. PA11/PA12 are the BlackPill's USB D-/D+ and are banned
	 * from carrier nets: D+ carries a 1.5k pull-up, and both contend with a USB
	 * cable that gets plugged in routinely for flashing and power. This net is
	 * therefore a ~10 mm run up the left column from D4 (b8) to PA8 (b4) through
	 * dead space, and it ends up closer to the MAX6675 header on the top edge
	 * than PA12 was. The C6 end is unchanged.
	 */
	cs-gpios = <&gpioa 15 GPIO_ACTIVE_LOW>,  /* LR1121_SSEL  (PA15, b9-left) */
		   <&gpioa 8 GPIO_ACTIVE_LOW>,   /* TEMP1_SSEL   (PA8,  b4-left) */
		   <&gpiob 0 GPIO_ACTIVE_LOW>;   /* TEMP2_SSEL   (PB0,  b6-right) */

	lora_lr1121: lora@0 {
		compatible = "semtech,lr1121";
		reg = <0>;
		spi-max-frequency = <DT_FREQ_M(16)>;

		reset-gpios = <&gpiob 6 GPIO_ACTIVE_LOW>;                        /* LR1121_RESET - PB6, b13 (D1) */
		busy-gpios  = <&gpiob 8 GPIO_ACTIVE_HIGH>;                       /* LR1121_BUSY  - PB8, b15 (D10) */
		event-gpios = <&gpiob 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;    /* LR1121_IRQ   - PB9, b16 (D11) */

		/* TODO: confirm against Core1121 R3/R4 population (HP only vs LP+HP). */
		lf-tx-path = <LR11XX_TX_PATH_LF_LP_HP>;

		lf-clk = <LR11XX_LFCLK_XTAL>;
		reg-mode = <LR11XX_REG_MODE_DCDC>;

		rf-sw-enable     = <(LR11XX_DIO5 | LR11XX_DIO6)>;
		rf-sw-rx-mode    = <LR11XX_DIO6>;
		rf-sw-tx-mode    = <LR11XX_DIO6>;
		rf-sw-tx-hp-mode = <LR11XX_DIO6>;
		rf-sw-tx-hf-mode = <LR11XX_DIO5>;
		rf-sw-wifi-mode  = <LR11XX_DIO5>;
		rf-sw-gnss-mode  = <LR11XX_DIO5>;

		tcxo-voltage = <LR11XX_TCXO_SUPPLY_1_8V>;
		tcxo-wakeup-time = <5>;

		tx-power-cfg-lf-lp =
		/* power, pa_duty_cycle, pa_hp_sel */
		<(-15) 0x00 0x00>, /* Expected output power = -17dBm */
		<(-14) 0x00 0x00>, /* Expected output power = -16dBm */
		<(-13) 0x00 0x00>, /* Expected output power = -15dBm */
		<(-12) 0x00 0x00>, /* Expected output power = -14dBm */
		<(-11) 0x00 0x00>, /* Expected output power = -13dBm */
		<(-9) 0x00 0x00>, /* Expected output power = -12dBm */
		<(-8) 0x00 0x00>, /* Expected output power = -11dBm */
		<(-7) 0x00 0x00>, /* Expected output power = -10dBm */
		<(-6) 0x00 0x00>, /* Expected output power = -9dBm */
		<(-5) 0x00 0x00>, /* Expected output power = -8dBm */
		<(-4) 0x00 0x00>, /* Expected output power = -7dBm */
		<(-3) 0x00 0x00>, /* Expected output power = -6dBm */
		<(-2) 0x00 0x00>, /* Expected output power = -5dBm */
		<(-1) 0x00 0x00>, /* Expected output power = -4dBm */
		<( 0) 0x00 0x00>, /* Expected output power = -3dBm */
		<( 1) 0x00 0x00>, /* Expected output power = -2dBm */
		<( 2) 0x00 0x00>, /* Expected output power = -1dBm */
		<( 3) 0x00 0x00>, /* Expected output power = 0dBm */
		<( 3) 0x01 0x00>, /* Expected output power = 1dBm */
		<( 4) 0x01 0x00>, /* Expected output power = 2dBm */
		<( 7) 0x00 0x00>, /* Expected output power = 3dBm */
		<( 8) 0x00 0x00>, /* Expected output power = 4dBm */
		<( 9) 0x00 0x00>, /* Expected output power = 5dBm */
		<( 10) 0x00 0x00>, /* Expected output power = 6dBm */
		<( 12) 0x00 0x00>, /* Expected output power = 7dBm */
		<( 13) 0x00 0x00>, /* Expected output power = 8dBm */
		<( 14) 0x00 0x00>, /* Expected output power = 9dBm */
		<( 13) 0x01 0x00>, /* Expected output power = 10dBm */
		<( 13) 0x02 0x00>, /* Expected output power = 11dBm */
		<( 14) 0x02 0x00>, /* Expected output power = 12dBm */
		<( 14) 0x03 0x00>, /* Expected output power = 13dBm */
		<( 14) 0x04 0x00>, /* Expected output power = 14dBm */
		<( 14) 0x07 0x00>; /* Expected output power = 15dBm */

		tx-power-cfg-lf-hp =
		/* power, pa_duty_cycle, pa_hp_sel */
		<(  9) 0x00 0x00>, /* Expected output power = -9dBm */
		<( 10) 0x00 0x00>, /* Expected output power = -8dBm */
		<( 11) 0x00 0x00>, /* Expected output power = -7dBm */
		<( 12) 0x00 0x00>, /* Expected output power = -6dBm */
		<( 13) 0x00 0x00>, /* Expected output power = -5dBm */
		<( 13) 0x01 0x00>, /* Expected output power = -4dBm */
		<( 13) 0x02 0x00>, /* Expected output power = -3dBm */
		<( 17) 0x02 0x00>, /* Expected output power = -2dBm */
		<( 14) 0x04 0x00>, /* Expected output power = -1dBm */
		<( 12) 0x00 0x01>, /* Expected output power = 0dBm */
		<( 13) 0x00 0x01>, /* Expected output power = 1dBm */
		<( 13) 0x01 0x01>, /* Expected output power = 2dBm */
		<( 13) 0x02 0x01>, /* Expected output power = 3dBm */
		<( 15) 0x00 0x02>, /* Expected output power = 4dBm */
		<( 15) 0x04 0x01>, /* Expected output power = 5dBm */
		<( 14) 0x02 0x02>, /* Expected output power = 6dBm */
		<( 14) 0x01 0x03>, /* Expected output power = 7dBm */
		<( 17) 0x04 0x02>, /* Expected output power = 8dBm */
		<( 22) 0x00 0x01>, /* Expected output power = 9dBm */
		<( 22) 0x01 0x01>, /* Expected output power = 10dBm */
		<( 22) 0x02 0x01>, /* Expected output power = 11dBm */
		<( 22) 0x03 0x01>, /* Expected output power = 12dBm */
		<( 22) 0x00 0x03>, /* Expected output power = 13dBm */
		<( 22) 0x01 0x03>, /* Expected output power = 14dBm */
		<( 22) 0x04 0x02>, /* Expected output power = 15dBm */
		<( 22) 0x01 0x04>, /* Expected output power = 16dBm */
		<( 22) 0x02 0x04>, /* Expected output power = 17dBm */
		<( 22) 0x01 0x06>, /* Expected output power = 18dBm */
		<( 22) 0x03 0x05>, /* Expected output power = 19dBm */
		<( 22) 0x03 0x07>, /* Expected output power = 20dBm */
		<( 22) 0x04 0x06>, /* Expected output power = 21dBm */
		<( 22) 0x04 0x07>; /* Expected output power = 22dBm */

		tx-power-cfg-hf =
		/* power, pa_duty_cycle, pa_hp_sel */
		<(-18) 0x04 0x00>, //Expected output power = -18dBm
		<(-18) 0x04 0x00>, /* Expected output power = -17dBm */
		<(-17) 0x04 0x00>, /* Expected output power = -16dBm */
		<(-16) 0x04 0x00>, /* Expected output power = -15dBm */
		<(-15) 0x04 0x00>, /* Expected output power = -14dBm */
		<(-14) 0x04 0x00>, /* Expected output power = -13dBm */
		<(-14) 0x04 0x00>, /* Expected output power = -12dBm */
		<(-12) 0x04 0x00>, /* Expected output power = -11dBm */
		<(-10) 0x04 0x00>, /* Expected output power = -10dBm */
		<( -9) 0x04 0x00>, /* Expected output power = -9dBm */
		<( -8) 0x04 0x00>, /* Expected output power = -8dBm */
		<( -7) 0x04 0x00>, /* Expected output power = -7dBm */
		<( -6) 0x04 0x00>, /* Expected output power = -6dBm */
		<( -5) 0x04 0x00>, /* Expected output power = -5dBm */
		<( -4) 0x04 0x00>, /* Expected output power = -4dBm */
		<( -3) 0x04 0x00>, /* Expected output power = -3dBm */
		<( -2) 0x03 0x00>, /* Expected output power = -2dBm */
		<( -1) 0x04 0x00>, /* Expected output power = -1dBm */
		<(  0) 0x04 0x00>, /* Expected output power = 0dBm */
		<(  1) 0x00 0x00>, /* Expected output power = 1dBm */
		<(  2) 0x00 0x00>, /* Expected output power = 2dBm */
		<(  4) 0x04 0x00>, /* Expected output power = 3dBm */
		<(  5) 0x04 0x00>, /* Expected output power = 4dBm */
		<(  6) 0x04 0x00>, /* Expected output power = 5dBm */
		<(  7) 0x04 0x00>, /* Expected output power = 6dBm */
		<(  8) 0x04 0x00>, /* Expected output power = 7dBm */
		<(  9) 0x04 0x00>, /* Expected output power = 8dBm */
		<( 10) 0x04 0x00>, /* Expected output power = 9dBm */
		<( 11) 0x04 0x00>, /* Expected output power = 10dBm */
		<( 12) 0x03 0x00>, /* Expected output power = 11dBm */
		<( 13) 0x04 0x00>, /* Expected output power = 12dBm */
		<( 13) 0x00 0x00>; /* Expected output power = 13dBm */


		/* Tune is G4 G5 G6 G7 G8 G9 G10 G11 G12 G13
		 * G13hp1 G13hp2 G13hp3 G13hp4 G13hp5 G13hp6 G13hp7
		 */
		rssi-calibration-lf-offset = <0>;
		rssi-calibration-lf-tune = <12 12 14 0 1 3 4 4 3 6 6 6 6 6 6 6 6>;

		rssi-calibration-mf-offset = <0>;
		rssi-calibration-mf-tune = <2 2 2 3 3 4 5 4 4 6 5 5 6 6 6 7 6>;

		rssi-calibration-hf-offset = <2030>;
		rssi-calibration-hf-tune = <6 7 6 4 3 4 14 12 14 12 12 12 12 8 8 9 9>;

		// Current consumptions
		tx-dbm-to-ua-reg-mode-dcdc-lf-lp-vreg = <
		10820 /* -17 dBm */
		10980 /* -16 dBm */
		11060 /* -15 dBm */
		11160 /* -14 dBm */
		11300 /* -13 dBm */
		11430 /* -12 dBm */
