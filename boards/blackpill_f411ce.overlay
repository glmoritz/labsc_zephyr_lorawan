		13150 /* -7 dBm */
		13460 /* -6 dBm */
		13770 /* -5 dBm */
		14070 /* -4 dBm */
		14460 /* -3 dBm */
		15030 /* -2 dBm */
		15440 /* -1 dBm */
		16030 /*  0 dBm */
		16980 /*  1 dBm */
		17590 /*  2 dBm */
		18270 /*  3 dBm */
		19060 /*  4 dBm */
		19900 /*  5 dBm */
		20740 /*  6 dBm */
		21610 /*  7 dBm */
		22400 /*  8 dBm */
		23370 /*  9 dBm */
		24860 /* 10 dBm */
		26410 /* 11 dBm */
		26430 /* 12 dBm */
		27890 /* 13 dBm */
		>;
	};

	/*
	 * Two MAX6675 K-type thermocouple-to-digital converters sharing SPI1.
	 * Read-only (SCK + SO/MISO + CS; no MOSI); SO tri-states when deselected.
	 */
	tc0: max6675@1 {
		compatible = "maxim,max6675";
		reg = <1>;                          /* CS index 1 -> PA3 */
		spi-max-frequency = <DT_FREQ_M(4)>;
	};

	tc1: max6675@2 {
		compatible = "maxim,max6675";
		reg = <2>;                          /* CS index 2 -> PA2 */
		spi-max-frequency = <DT_FREQ_M(4)>;
	};
};

/*
 * STM32F411CE has no storage_partition, and its default MCUboot slots (128K) are
 * far too small for USP (~400K). Use a bare (non-MCUboot) layout: a large code
 * partition plus a 128K storage sector. On STM32F4 the top flash sector is 128K
 * (the smallest independently erasable unit up there), so storage = that sector.
 */
/ {
	chosen {
		zephyr,code-partition = &slot0_partition;
	};
};

&flash0 {
	/delete-node/ partitions;

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		slot0_partition: partition@0 {
			label = "image-0";
			reg = <0x00000000 DT_SIZE_K(384)>;
		};
		storage_partition: partition@60000 {
			label = "storage";
			reg = <0x00060000 DT_SIZE_K(128)>;
		};
	};
};
