		25050 /* 11 dBm */
		26350 /* 12 dBm */
		27870 /* 13 dBm */
		28590 /* 14 dBm */
		37820 /* 15 dBm */
		>;

		tx-dbm-to-ua-reg-mode-ldo-lf-lp-vreg = <
		14950 /* -17 dBm */
		15280 /* -16 dBm */
		15530 /* -15 dBm */
